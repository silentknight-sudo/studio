{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["Admin", "Manager", "Employee"],
          "description": "The user's role in the system."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL for the user's profile photo."
        }
      },
      "required": ["email", "role"]
    },
    "Department": {
      "title": "Department",
      "description": "Represents a department in the company.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the department."
        }
      },
      "required": ["name"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Represents an employee in the company.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Manager", "Employee"] },
        "departmentId": { "type": "string" },
        "teamId": { "type": "string" },
        "dateOfJoining": { "type": "string", "format": "date" },
        "monthlyBaseSalary": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "profilePhotoUrl": { "type": "string", "format": "uri" },
        "address": { "type": "string" },
        "emergencyContact": { "type": "string" }
      },
      "required": ["fullName", "email", "role", "departmentId", "dateOfJoining", "monthlyBaseSalary", "status"]
    },
    "EmployeeDocument": {
      "title": "Employee Document",
      "description": "Metadata for files attached to an employee profile.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Contract", "ID Proof", "Tax Form", "Other"] },
        "uploadDate": { "type": "string", "format": "date" },
        "fileUrl": { "type": "string" }
      }
    },
    "Advance": {
        "title": "Salary Advance",
        "description": "Represents a salary advance given to an employee.",
        "type": "object",
        "properties": {
            "employeeId": { "type": "string" },
            "amount": { "type": "number" },
            "issueDate": { "type": "string", "format": "date" },
            "repaymentType": { "type": "string", "enum": ["Single-month", "Multi-month"] },
            "installments": { "type": "number" },
            "remainingBalance": { "type": "number" }
        },
        "required": ["employeeId", "amount", "issueDate", "repaymentType", "installments", "remainingBalance"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores public profile information for each user."
    },
    "/departments/{departmentId}": {
      "schema": { "$ref": "#/entities/Department" },
      "description": "Collection of all departments."
    },
    "/employees/{employeeId}": {
      "schema": { "$ref": "#/entities/Employee" },
      "description": "Collection of all employees."
    },
    "/employees/{employeeId}/documents/{docId}": {
      "schema": { "$ref": "#/entities/EmployeeDocument" },
      "description": "Sub-collection for employee documents metadata."
    },
    "/advances/{advanceId}": {
        "schema": { "$ref": "#/entities/Advance" },
        "description": "Collection of all salary advances."
    }
  }
}
