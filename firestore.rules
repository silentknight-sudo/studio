rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This is an insecure rule. It allows anyone to read and write to your database.
    // It is intended for development and testing only.
    // You should secure your database before going to production.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
